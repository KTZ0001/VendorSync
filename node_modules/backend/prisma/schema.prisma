generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Enums are replaced with Strings for SQLite compatibility
// Roles: PROCUREMENT_OFFICER, VENDOR, MANAGER, ADMIN
// RFQ Status: DRAFT, PUBLISHED, CLOSED, COMPLETED
// PO Status: PENDING, ISSUED, CANCELLED

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role      String   @default("PROCUREMENT_OFFICER")
  vendorId  String?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  rfqs      RFQ[]    @relation("Creator")
  approvals Approval[]
  createdAt DateTime @default(now())
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  category    String
  gstNumber   String   @unique
  status      String   @default("ACTIVE")
  contactName String
  email       String   @unique
  quotations  Quotation[]
  users       User[]
  pos         PurchaseOrder[]
}

model RFQ {
  id          String      @id @default(uuid())
  title       String
  number      String      @unique 
  description String
  deadline    DateTime
  status      String      @default("DRAFT")
  items       String      // SQLite handles Json as String, store as JSON string
  creatorId   String
  creator     User        @relation("Creator", fields: [creatorId], references: [id])
  quotations  Quotation[]
  createdAt   DateTime    @default(now())
}

model Quotation {
  id           String   @id @default(uuid())
  rfqId        String
  rfq          RFQ      @relation(fields: [rfqId], references: [id])
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  unitPrice    Float
  totalPrice   Float
  deliveryDays Int
  notes        String?
  status       String   @default("SUBMITTED") 
  po           PurchaseOrder?
  createdAt    DateTime @default(now())
}

model PurchaseOrder {
  id          String    @id @default(uuid())
  poNumber    String    @unique
  quotationId String    @unique
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  vendorId    String
  vendor      Vendor    @relation(fields: [vendorId], references: [id])
  status      String    @default("PENDING")
  totalAmount Float
  taxAmount   Float
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
}

model Invoice {
  id        String   @id @default(uuid())
  invNumber String   @unique
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id])
  amount    Float
  status    String   @default("UNPAID")
  paidAt    DateTime?
}

model Approval {
  id        String   @id @default(uuid())
  entityId  String   
  entityType String  
  approverId String
  approver   User    @relation(fields: [approverId], references: [id])
  status     String  
  remarks    String?
  createdAt  DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  details   String
  userId    String
  createdAt DateTime @default(now())
}
